NODE_ENV=development
PORT=3000

# PostgreSQL connection (prefer DATABASE_URL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eventdb_core
DB_SSL=false

# EventDB defaults
DEFAULT_NAMESPACE_ID=default
EVENT_GENESIS_PREV_HASH=GENESIS
SEAL_GENESIS_PREV_HASH=SEAL_GENESIS

# Signature verification mode:
# - none: only checks signature field non-empty
# - hmac_sha256: verifies signature = hex(HMAC_SHA256(canonical_input, account_secret))
SIGNATURE_MODE=none

# JSON map account_id -> secret for SIGNATURE_MODE=hmac_sha256
# Example: {"acct-ops-01":"secret-ops","acct-seal-01":"secret-seal"}
ACCOUNT_SECRETS_JSON={}
