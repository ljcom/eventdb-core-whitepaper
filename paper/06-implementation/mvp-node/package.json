{
  "name": "eventdb-core-mvp-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "EventDB Core MVP service (Node.js + PostgreSQL)",
  "scripts": {
    "dev": "node --watch src/app.js",
    "start": "node src/app.js",
    "check": "node --check src/app.js && node --check src/builders.js && node --check src/verification.js && node --check scripts/load-sample.js && node --check tests/integration.test.js",
    "db:schema": "node scripts/apply-schema.js",
    "sample:load": "node scripts/load-sample.js",
    "test:integration": "node --test tests/integration.test.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0"
  }
}
